# --- OS ---
.DS_Store
Thumbs.db

# --- Office lock-файлы ---
~$*.docx
~$*.xlsx

# --- Secrets / env ---
.env
.env.local
.env.*.local
.env.prod
# .env.example и .env.prod.example — коммитим (шаблоны без секретов)

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.eggs/
*.egg-info/
*.egg

# --- Test / lint cache ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.hypothesis/

# --- Alembic версия БД (на случай если кто-то локально создавал) ---
# Сами миграции коммитим (migrations/versions/*.py).
# alembic.ini тоже коммитим — это конфиг, не секрет.

# --- ML datasets (большие, не git'абельные) ---
ml/data/raw/
# Папка `processed/` исключается по содержимому (`*`), а не как директория —
# иначе git не заходит в неё и `!`-исключения ниже не работают.
ml/data/processed/*
ml/data/interim/
ml/artifacts/
ml/models/
# Но карточку датасета, лицензии и каталог упражнений — коммитим как
# документацию + сидер миграции 0016 их читает.
!ml/data/processed/dataset_card.md
!ml/data/processed/LICENSES.md
!ml/data/processed/exercises_catalog.json
!ml/data/processed/exercises_catalog_ru.json
*.parquet
*.h5
*.pkl
*.joblib
*.onnx

# --- Flutter / Dart ---
pwa/.dart_tool/
pwa/.flutter-plugins
pwa/.flutter-plugins-dependencies
pwa/.packages
pwa/build/
pwa/ios/Pods/
pwa/.pub-cache/
pwa/.pub/
pwa/coverage/
# pwa/.metadata — коммитим (фиксирует версию Flutter create)
# pwa/pubspec.lock — коммитим (это application, не library)

# Flutter web build артефакты
pwa/web/main.dart.js
pwa/web/main.dart.js.map
pwa/web/flutter_service_worker.js

# --- IDE / Editor ---
.idea/
.vscode/
*.iml
*.swp
*.swo
*~
.fleet/
.zed/

# --- Claude Code (приватные настройки) ---
.claude/

# --- Docker volumes (создаются runtime'ом, не для git) ---
deploy/postgres/data/
deploy/minio/data/

# --- Логи ---
*.log
logs/
