# Шаблон production .env для fitness-tracker.geox55.ru.
# Скопируйте в .env.prod и заполните секреты (`.env.prod` в .gitignore).
#
# Все три секрета — сгенерировать `openssl rand -base64 32`:
#   POSTGRES_PASSWORD, JWT_SECRET, S3_SECRET_KEY.

# --- Postgres -------------------------------------------------------------
POSTGRES_USER=app
POSTGRES_PASSWORD=__GENERATE_ME__
POSTGRES_DB=fitness

# --- API ------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://app:__GENERATE_ME__@postgres:5432/fitness
JWT_SECRET=__GENERATE_ME__
ENV=production

# Same-origin: PWA и API на одном домене, поэтому CORS реально не нужен,
# но cors_origins в config.py не может быть пустым — задаём явно.
# Single quotes обязательны: docker compose v2.5+ стрипает голые double quotes
# в значениях .env, и pydantic потом не парсит JSON-массив.
CORS_ORIGINS='["https://fitness-tracker.geox55.ru"]'

# Базовый URL приложения — используется в письмах подтверждения и сбросов.
APP_BASE_URL=https://fitness-tracker.geox55.ru

# Email verification отключён в MVP (см. specs/001 §10).
# Когда подключим реальный SMTP — поставить true.
EMAIL_VERIFICATION_REQUIRED=false

# --- SMTP -----------------------------------------------------------------
# Пустой SMTP_HOST → LoggingEmailSender (письма уходят в логи api).
# Для реальной отправки заполнить и поставить EMAIL_VERIFICATION_REQUIRED=true.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
SMTP_STARTTLS=true
EMAIL_FROM=noreply@fitness-tracker.geox55.ru

# --- S3 (MinIO в нашем docker compose) ------------------------------------
# Внутри docker-сети — http://minio:9000. Наружу отдаём через nginx subpath
# /s3/, чтобы подписанные URL были same-origin (см. deploy/nginx/nginx.prod.conf).
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_BASE_URL=https://fitness-tracker.geox55.ru/s3
S3_ACCESS_KEY=fitness
S3_SECRET_KEY=__GENERATE_ME__
S3_BUCKET=fitness-uploads
S3_REGION=us-east-1

# --- Cleanup --------------------------------------------------------------
# Интервал для api-cleanup (spec 013 REQ-08). Дефолт — 1 час.
PDF_CLEANUP_INTERVAL_SECONDS=3600

# --- PWA build args -------------------------------------------------------
# Передаётся в --dart-define при flutter build web. Должен совпадать
# с публичным префиксом /api/v1 на том же домене.
API_BASE_URL=https://fitness-tracker.geox55.ru/api/v1

# --- Мониторинг (docker-compose.monitoring.yml, см. deploy/README.md) -----
# Обязательно для `make monitoring-up` на сервере (пароль входа в Grafana).
GF_SECURITY_ADMIN_PASSWORD=__GENERATE_ME__
# Публичный URL Grafana (редиректы, ссылки в UI). Должен совпадать с DNS.
GRAFANA_ROOT_URL=https://logs.fitness-tracker.geox55.ru

# TLS выпускает встроенный ACME Angie (см. deploy/README.md), не host-certbot.
